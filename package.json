{
  "name": "@xerxisfy/xon",
  "version": "1.0.0",
  "description": "Xon (Xerxis Object Notation) parser, CLI, and language bindings",
  "main": "index.js",
  "types": "bindings/xon.d.ts",
  "homepage": "https://github.com/xerxisfy/xon",
  "bugs": {
    "url": "https://github.com/xerxisfy/xon/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "xon": "./bin/xon"
  },
  "scripts": {
    "build": "./build.sh",
    "install": "node-gyp rebuild",
    "pack:preview": "npm pack --dry-run",
    "test": "./scripts/run_tests.sh",
    "test:c": "gcc -Wall -Wextra -std=c99 -Iinclude -o /tmp/xon_test_suite tests/test_suite.c src/xon_api.c src/lexer.c src/logger.c && /tmp/xon_test_suite",
    "test:python": "python3 tests/test_python.py",
    "prepublishOnly": "./scripts/run_tests.sh && npm pack --dry-run",
    "publish:package": "npm publish"
  },
  "keywords": [
    "xon",
    "config",
    "configuration",
    "json",
    "parser",
    "native"
  ],
  "author": "Isaac Muliro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xerxisfy/xon"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "bindings/",
    "include/",
    "src/",
    "scripts/",
    "tools/lemon",
    "tools/lempar.c",
    "build.sh",
    "binding.gyp",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "gypfile": true,
  "dependencies": {
    "node-addon-api": "^7.0.0"
  },
  "devDependencies": {
    "node-gyp": "^10.0.0"
  }
}
